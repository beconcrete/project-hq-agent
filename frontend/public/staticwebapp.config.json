{
  "routes": [
    {
      "route": "/sample.html",
      "allowedRoles": ["anonymous"]
    },
    {
      "route": "/api/*",
      "allowedRoles": ["anonymous"]
    }
  ],
  "navigationFallback": {
    "rewrite": "/index.html",
    "exclude": [
      "/assets/*",
      "*.{css,scss,js,png,gif,ico,jpg,svg,woff,woff2,ttf,eot,html}"
    ]
  },
  "responseOverrides": {
    "404": {
      "rewrite": "/index.html",
      "statusCode": 200
    }
  },
  "globalHeaders": {
    "X-Content-Type-Options": "nosniff",
    "X-Frame-Options": "SAMEORIGIN",
    "Content-Security-Policy": "default-src 'self'; script-src 'self' 'unsafe-inline'; worker-src blob:; style-src 'self' 'unsafe-inline'; font-src 'self' data:; connect-src 'self' wss: https://*.auth0.com https://id.beconcrete.se"
  },
  "platform": {
    "apiRuntime": "dotnet-isolated:8.0"
  },
  "mimeTypes": {
    ".json": "application/json"
  }
}
